@model MVCLab1.Models.CalculateDiscount

<h2>Discount Calculation System</h2>

@using (Html.BeginForm("Calculate", "Home"))
{
    <div>
        @Html.LabelFor(m => m.Price)
        @Html.TextBoxFor(m => m.Price, new { @id = "price" })
        @Html.ValidationMessageFor(m => m.Price, "", new { id = "PriceError", style = "color:red" })
    </div>
    <div>
        @Html.LabelFor(m => m.DiscountPercentage)
        @Html.TextBoxFor(m => m.DiscountPercentage, new { @id = "disc" })
        @Html.ValidationMessageFor(m => m.DiscountPercentage, "", new { id = "DiscError", style = "color:red" })
    </div>
    <input type="submit" value="Calculate" id="calculate"/>
}






