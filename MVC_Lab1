using System;
using System.Collections.Generic;
using System.ComponentModel.DataAnnotations;
using System.Linq;
using System.Web;

namespace MVCLab1.Models
{
    public class CalculateDiscount
    {
        [Display(Name = "Enter Item Price")]
        [Required(ErrorMessage = "Please Enter a valid Number")]
        [Range(0, Int32.MaxValue, ErrorMessage = "The Field Enter Item Price must be a number.")]
        public int Price {  get; set; }

        [Display(Name = "Discount Percentage")]
        [Required(ErrorMessage = "Please Enter a value between 0 and 100")]
        [Range(0, 100, ErrorMessage = "The Field Discount Percentage must be a number.")]

        public double DiscountPercentage {  get; set; }

        [Display(Name = "Discount Amount")]
        public double DiscountAmount {  get; set; }

        [Display(Name = "Amount to be paid")]
        public double Total {  get; set; }

    }
}





Controllers->HomeController.cs:

using MVCLab1.Models;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Web;
using System.Web.Mvc;

namespace MVCLab1.Controllers
{
    public class HomeController : Controller
    {
        public ActionResult Index()
        {
            return View(new CalculateDiscount());
        }
        public ActionResult Calculate(CalculateDiscount calc)
        {
            if (ModelState.IsValid)
            { 
                calc.DiscountAmount = (calc.DiscountPercentage * calc.Price) / 100;
                calc.Total = calc.Price - calc.DiscountAmount;
                return View(calc);
            }
            return View("Index");
        }

        public ActionResult About()
        {
            ViewBag.Message = "Your application description page.";

            return View();
        }

        public ActionResult Contact()
        {
            ViewBag.Message = "Your contact page.";

            return View();
        }
    }
}









