<div>
    @{
        var price = 45;

        if (price > 30)
        {
            <h3>Price is Higher than 30.</h3>
        }
        else if (price == 30)
        {
            <h3>Price is Equal to 30.</h3>
        }
        else
        {
            <h3>Price is Lower than 30.</h3>
        }
    }
</div>


