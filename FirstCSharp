using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace FirstConsoleProject
{
    public class Emp
    {
        private int _ecode;
        private string _name;
        public void input()
        {
            Console.WriteLine("Enter your ID:");
            _ecode = Convert.ToInt32(Console.ReadLine());
            Console.WriteLine("Enter your Name:");
            _name = Console.ReadLine();

        }
        public void display()
        {
            Console.WriteLine("Emp code : " + _ecode + " Name : " + _name);

        }

    }
}







